                <!-- Seasonal Collection 3 -->
                <div class="collection-card" data-category="seasonal">
                    <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=750&fit=crop" alt="Autumn Harvest" class="collection-image">
