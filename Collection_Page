<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Surface Pattern Design Portfolio | Curious Hands. Creative Heart.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --color-cream: #FAF7F2;
            --color-charcoal: #2C2C2C;
            --color-terracotta: #D4846A;
            --color-sage: #9CAF88;
            --color-slate: #5D6D7E;
            --color-gold: #C9A66B;
            
            --font-display: 'Cormorant Garamond', serif;
            --font-body: 'Outfit', sans-serif;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: var(--font-body);
            color: var(--color-charcoal);
            background-color: var(--color-cream);
            line-height: 1.6;
            overflow-x: hidden;
        }
        
        /* Header */
        header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 4rem;
            background: rgba(250, 247, 242, 0.95);
            backdrop-filter: blur(10px);
            z-index: 1000;
            border-bottom: 1px solid rgba(44, 44, 44, 0.1);
            animation: slideDown 0.6s ease-out;
        }
        
        @keyframes slideDown {
            from {
                transform: translateY(-100%);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }
        
        .logo {
            font-family: var(--font-display);
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--color-charcoal);
            letter-spacing: 0.5px;
            opacity: 0;
            animation: fadeIn 0.8s ease-out 0.3s forwards;
        }
        
        nav ul {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }
        
        nav a {
            font-family: var(--font-body);
            font-size: 0.95rem;
            font-weight: 400;
            color: var(--color-charcoal);
            text-decoration: none;
            letter-spacing: 0.5px;
            position: relative;
            transition: color 0.3s ease;
            opacity: 0;
            animation: fadeIn 0.8s ease-out forwards;
        }
        
        nav a:nth-child(1) { animation-delay: 0.4s; }
        nav a:nth-child(2) { animation-delay: 0.5s; }
        nav a:nth-child(3) { animation-delay: 0.6s; }
        nav a:nth-child(4) { animation-delay: 0.7s; }
        
        nav a::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 1px;
            background: var(--color-terracotta);
            transition: width 0.3s ease;
        }
        
        nav a:hover {
            color: var(--color-terracotta);
        }
        
        nav a:hover::after {
            width: 100%;
        }
        
        @keyframes fadeIn {
            to {
                opacity: 1;
            }
        }
        
        /* Hero Section */
        .hero {
            margin-top: 85px;
            height: 75vh;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: linear-gradient(135deg, #E8DDD3 0%, #D4C5B9 100%);
        }
        
        .hero-image {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.3;
            filter: grayscale(20%);
            animation: heroZoom 20s ease-in-out infinite alternate;
        }
        
        @keyframes heroZoom {
            from {
                transform: scale(1);
            }
            to {
                transform: scale(1.08);
            }
        }
        
        .hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, transparent 0%, rgba(250, 247, 242, 0.4) 100%);
        }
        
        .hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            padding: 2rem;
            opacity: 0;
            animation: heroFadeUp 1.2s ease-out 0.8s forwards;
        }
        
        @keyframes heroFadeUp {
            from {
                transform: translateY(30px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }
        
        .hero-slogan {
            font-family: var(--font-display);
            font-size: 5rem;
            font-weight: 300;
            color: var(--color-charcoal);
            line-height: 1.2;
            margin-bottom: 1rem;
            letter-spacing: 1px;
        }
        
        .hero-subtext {
            font-family: var(--font-body);
            font-size: 1.2rem;
            font-weight: 300;
            color: var(--color-slate);
            letter-spacing: 2px;
            text-transform: uppercase;
        }
        
        /* Collections Section */
        .collections-section {
            padding: 6rem 4rem;
            max-width: 1600px;
            margin: 0 auto;
        }
        
        .section-header {
            text-align: center;
            margin-bottom: 5rem;
            opacity: 0;
            animation: fadeInUp 0.8s ease-out forwards;
            animation-play-state: paused;
        }
        
        .section-header.visible {
            animation-play-state: running;
        }
        
        @keyframes fadeInUp {
            from {
                transform: translateY(30px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }
        
        .section-title {
            font-family: var(--font-display);
            font-size: 3.5rem;
            font-weight: 400;
            color: var(--color-charcoal);
            margin-bottom: 1rem;
        }
        
        .section-subtitle {
            font-family: var(--font-body);
            font-size: 1.1rem;
            font-weight: 300;
            color: var(--color-slate);
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.8;
        }
        
        /* Collection Grid */
        .collection-category {
            margin-bottom: 6rem;
        }
        
        .category-header {
            text-align: center;
            margin-bottom: 3rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid rgba(44, 44, 44, 0.1);
        }
        
        .category-title {
            font-family: var(--font-display);
            font-size: 2.8rem;
            font-weight: 400;
            color: var(--color-charcoal);
            margin-bottom: 1rem;
        }
        
        .category-description {
            font-family: var(--font-body);
            font-size: 1rem;
            font-weight: 300;
            color: var(--color-slate);
            max-width: 600px;
            margin: 0 auto 1.5rem;
            line-height: 1.8;
        }
        
        .category-link {
            display: inline-block;
            font-family: var(--font-body);
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--color-terracotta);
            text-decoration: none;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            position: relative;
        }
        
        .category-link::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 100%;
            height: 1px;
            background: var(--color-terracotta);
            transform: scaleX(0);
            transform-origin: right;
            transition: transform 0.3s ease;
        }
        
        .category-link:hover::after {
            transform: scaleX(1);
            transform-origin: left;
        }
        
        .collection-category:last-of-type {
            margin-bottom: 0;
        }
        
        .collections-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 3rem;
            margin-bottom: 4rem;
        }
        
        .collection-card {
            position: relative;
            aspect-ratio: 4/5;
            overflow: hidden;
            border-radius: 2px;
            background: var(--color-charcoal);
            cursor: pointer;
            opacity: 0;
            animation: fadeInScale 0.8s ease-out forwards;
            animation-play-state: paused;
        }
        
        .collection-card.visible {
            animation-play-state: running;
        }
        
        @keyframes fadeInScale {
            from {
                transform: scale(0.95);
                opacity: 0;
            }
            to {
                transform: scale(1);
                opacity: 1;
            }
        }
        
        .collection-card:nth-child(1) { animation-delay: 0.1s; }
        .collection-card:nth-child(2) { animation-delay: 0.2s; }
        .collection-card:nth-child(3) { animation-delay: 0.3s; }
        .collection-card:nth-child(4) { animation-delay: 0.4s; }
        .collection-card:nth-child(5) { animation-delay: 0.5s; }
        .collection-card:nth-child(6) { animation-delay: 0.6s; }
        .collection-card:nth-child(7) { animation-delay: 0.7s; }
        
        .collection-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .collection-card:hover .collection-image {
            transform: scale(1.05);
        }
        
        .collection-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 2.5rem 2rem;
            background: linear-gradient(to top, rgba(44, 44, 44, 0.95) 0%, transparent 100%);
            transform: translateY(0);
            transition: transform 0.4s ease;
        }
        
        .collection-card:hover .collection-overlay {
            transform: translateY(-10px);
        }
        
        .collection-name {
            font-family: var(--font-display);
            font-size: 2rem;
            font-weight: 400;
            color: var(--color-cream);
            margin-bottom: 0.5rem;
            letter-spacing: 0.5px;
        }
        
        .collection-description {
            font-family: var(--font-body);
            font-size: 0.95rem;
            font-weight: 300;
            color: rgba(250, 247, 242, 0.8);
            line-height: 1.6;
            opacity: 0;
            transform: translateY(10px);
            transition: all 0.4s ease 0.1s;
        }
        
        .collection-card:hover .collection-description {
            opacity: 1;
            transform: translateY(0);
        }
        
        .collection-tag {
            display: inline-block;
            margin-top: 0.8rem;
            padding: 0.4rem 1rem;
            font-size: 0.75rem;
            font-weight: 400;
            letter-spacing: 1px;
            text-transform: uppercase;
            background: var(--color-terracotta);
            color: white;
            border-radius: 20px;
            opacity: 0;
            transform: translateY(10px);
            transition: all 0.4s ease 0.2s;
        }
        
        .collection-card:hover .collection-tag {
            opacity: 1;
            transform: translateY(0);
        }
        
        /* CTA Section (StoryBrand) */
        .cta-section {
            background: linear-gradient(135deg, var(--color-sage) 0%, var(--color-slate) 100%);
            padding: 5rem 4rem;
            text-align: center;
            margin: 4rem 0 0;
        }
        
        .cta-content {
            max-width: 700px;
            margin: 0 auto;
        }
        
        .cta-title {
            font-family: var(--font-display);
            font-size: 3rem;
            font-weight: 400;
            color: white;
            margin-bottom: 1.5rem;
        }
        
        .cta-text {
            font-family: var(--font-body);
            font-size: 1.2rem;
            font-weight: 300;
            color: rgba(255, 255, 255, 0.9);
            margin-bottom: 2.5rem;
            line-height: 1.8;
        }
        
        .cta-button {
            display: inline-block;
            padding: 1rem 3rem;
            font-family: var(--font-body);
            font-size: 1rem;
            font-weight: 500;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--color-charcoal);
            background: var(--color-cream);
            border: none;
            border-radius: 2px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        }
        
        .cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 30px rgba(0, 0, 0, 0.3);
            background: white;
        }
        
        /* Footer */
        footer {
            background: var(--color-charcoal);
            color: var(--color-cream);
            padding: 3rem 4rem;
            text-align: center;
        }
        
        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .footer-text {
            font-family: var(--font-body);
            font-size: 0.9rem;
            font-weight: 300;
            opacity: 0.7;
        }
        
        /* Responsive */
        @media (max-width: 1024px) {
            .collections-grid {
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: 2rem;
            }
            
            .hero-slogan {
                font-size: 3.5rem;
            }
        }
        
        @media (max-width: 768px) {
            header {
                padding: 1rem 2rem;
                flex-direction: column;
                gap: 1rem;
            }
            
            nav ul {
                gap: 1.5rem;
            }
            
            .hero {
                height: 60vh;
            }
            
            .hero-slogan {
                font-size: 2.5rem;
            }
            
            .hero-subtext {
                font-size: 1rem;
            }
            
            .collections-section {
                padding: 4rem 2rem;
            }
            
            .section-title {
                font-size: 2.5rem;
            }
            
            .collections-grid {
                grid-template-columns: 1fr;
            }
            
            .cta-section {
                padding: 3rem 2rem;
            }
            
            .cta-title {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header>
