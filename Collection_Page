                    </div>
                </div>

                <!-- Seasonal Collection 4 -->
                <div class="collection-card" data-category="seasonal">
                    <img src="https://images.unsplash.com/photo-1483728642387-6c3bdd6c93e5?w=600&h=750&fit=crop" alt="Winter Frost" class="collection-image">
                    <div class="collection-overlay">
                        <h3 class="collection-name">Winter Frost</h3>
                        <p class="collection-description">Crystalline beauty and evergreen elegance. Snowflakes, holly, and serene winter whites.</p>
