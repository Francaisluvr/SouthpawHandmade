            </div>
            
            <div class="collections-grid">
                <!-- Character Collection 1 -->
                <div class="collection-card" data-category="character">
                    <img src="https://images.unsplash.com/photo-1518709268805-4e9042af9f23?w=600&h=750&fit=crop" alt="Golden Courage" class="collection-image">
                    <div class="collection-overlay">
                        <h3 class="collection-name">Golden Courage</h3>
                        <p class="collection-description">Bold golds, deep blues, and regal accents. A pattern fit for adventure and bravery.</p>
                        <span class="collection-tag">View Patterns</span>
